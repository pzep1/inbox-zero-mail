// Copy this file to Config/LocalSecrets.xcconfig and fill in your own values.
// That file is ignored by git.
//
// Create a Google OAuth client of type "Desktop app" and paste the values here.
// Do not commit real credentials.

INBOX_ZERO_GMAIL_CLIENT_ID = your-desktop-client-id.apps.googleusercontent.com
INBOX_ZERO_GMAIL_CLIENT_SECRET = your-desktop-client-secret

// Optional Outlook/Microsoft Entra public client for local testing.
INBOX_ZERO_OUTLOOK_CLIENT_ID = your-outlook-client-id
INBOX_ZERO_OUTLOOK_CLIENT_SECRET =

// Optional image-proxy signing for local/private builds. If you ship this in a
// public desktop build, users can extract it, so use a separate low-trust proxy
// secret or an unsigned/authenticated proxy designed for desktop clients.
INBOX_ZERO_IMAGE_PROXY_BASE_URL = https://img.getinboxzero.com/proxy
INBOX_ZERO_IMAGE_PROXY_SIGNING_SECRET =

// Optional for local Sparkle testing when using the direct-download release lane.
// The GitHub release workflow injects these values in CI for signed release builds.
SLASH = /
SPARKLE_APPCAST_URL = https:$(SLASH)$(SLASH)your-name.github.io$(SLASH)inbox-zero-mail$(SLASH)appcast.xml
SPARKLE_PUBLIC_ED_KEY = your-sparkle-public-ed25519-key
